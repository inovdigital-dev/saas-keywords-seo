generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id // Supabase auth user UUID
  email     String   @unique
  createdAt DateTime @default(now())
  jobs      Job[]
}

model Job {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String?
  country       String       @default("pt") // ISO 2-letter code for Ahrefs keyword research
  toneOfVoice   String?      @db.Text
  introMaxChars Int?
  outroMaxChars Int?
  status        JobStatus    @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?
  results       JobResult[]

  @@index([userId])
}

model JobResult {
  id        String        @id @default(cuid())
  jobId     String
  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  url       String
  status    ResultStatus  @default(PENDING)
  keywords        Json?    // Array<{keyword, searchVolume, difficulty, score, isValid}>
  introText       String?  @db.Text
  introKeywordMap Json?    // Array<{original, used}> — keyword adaptations in intro text
  outroText       String?  @db.Text
  outroKeywordMap Json?    // Array<{original, used}> — keyword adaptations in outro text
  error           String?  @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([jobId])
  @@index([url])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ResultStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
